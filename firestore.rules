rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    //  FUNCIONES DE APOYO (HELPERS)
    // -------------------------------------------------------------------------

    // Verifica si el usuario ha iniciado sesión
    function isAuthenticated() {
      return request.auth != null;
    }

    // Obtiene el documento del usuario actual desde la colección 'users'
    // IMPORTANTE: Esto consume 1 lectura por cada evaluación de regla.
    // Solo usarla donde sea indispensable (plan Spark).
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Verifica si el usuario es SUPER ADMIN leyendo su documento en 'users'
    function isSuperAdmin() {
      return isAuthenticated() && getUserData().rol == 'superadmin';
    }

    // Verifica si el documento pertenece al usuario actual (gratis, no consume lecturas)
    function isOwner() {
      return isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // -------------------------------------------------------------------------
    //  1. USUARIOS
    // -------------------------------------------------------------------------
    match /users/{userId} {
      // Regla de Oro: un usuario SIEMPRE puede leer/escribir su propio perfil
      allow read, create, update: if isAuthenticated() && request.auth.uid == userId;

      // SuperAdmin: gestión total de usuarios
      allow read, write: if isSuperAdmin();
    }

    // -------------------------------------------------------------------------
    //  2. ESCUELAS
    // -------------------------------------------------------------------------
    match /schools/{schoolId} {
      // Lectura: cualquier autenticado (necesario para el onboarding: buscar/unirse)
      allow read: if isAuthenticated();

      // Crear/actualizar: cualquier autenticado
      // (el onboarding crea escuelas y actualiza estadísticas al unirse un docente)
      allow create, update: if isAuthenticated();

      // Borrar: solo SuperAdmin
      allow delete: if isSuperAdmin();
    }

    // -------------------------------------------------------------------------
    //  3. ALUMNOS (datos sensibles de menores: CURP, teléfonos, situación familiar)
    // -------------------------------------------------------------------------
    match /alumnos/{alumnoId} {
      // Crear: PÚBLICO — la página /registro la llenan alumnos sin cuenta
      allow create: if true;

      // Leer/editar/borrar: solo personal autenticado (docentes, directivos)
      // NUNCA lectura pública: protege los datos de los menores
      allow read, update, delete: if isAuthenticated();
    }

    // -------------------------------------------------------------------------
    //  4. CUESTIONARIOS SOCIOEDUCATIVOS (mismo criterio que alumnos)
    // -------------------------------------------------------------------------
    match /cuestionariosSocioEducativos/{cuestionarioId} {
      allow create: if true;
      allow read, update, delete: if isAuthenticated();
    }

    // -------------------------------------------------------------------------
    //  5. PLANEACIONES (el docente es dueño de las suyas)
    // -------------------------------------------------------------------------
    match /planeaciones/{planId} {
      // Leer: cualquier docente autenticado (permite compartir dentro de la escuela)
      allow read: if isAuthenticated();

      // Crear: cualquier autenticado
      allow create: if isAuthenticated();

      // Editar/borrar: el dueño de la planeación, o SuperAdmin
      allow update, delete: if isOwner() || isSuperAdmin();
    }

    // -------------------------------------------------------------------------
    //  6. FICHAS 12 (taller reflexivo personal del docente)
    // -------------------------------------------------------------------------
    match /fichas12/{fichaId} {
      allow read, create: if isAuthenticated();
      allow update, delete: if isOwner() || isSuperAdmin();
    }

    // -------------------------------------------------------------------------
    //  7. RESTO DEL SISTEMA (materias, asignaciones, pmc, herramientas, etc.)
    // -------------------------------------------------------------------------
    // Solo usuarios autenticados. Nada del sistema es legible desde internet
    // sin iniciar sesión.
    match /{document=**} {
      allow read, write: if isAuthenticated();
    }
  }
}
