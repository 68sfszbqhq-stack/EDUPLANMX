# Gemini API Key — YA NO SE USA, NO LA PONGAS AQUÍ.
#
# Esta app se publica como sitio estático: cualquier variable VITE_* queda dentro
# del JavaScript que sirve GitHub Pages, o sea que sería una clave PÚBLICA que
# cualquiera puede extraer y usar contra la cuenta que la generó.
#
# Cada docente pega su propia clave gratuita dentro de la app (se guarda solo en
# sessionStorage de su navegador). Obtenerla toma un minuto:
# https://aistudio.google.com/apikey

# Firebase Configuration (Públicas - de Firebase Console)
VITE_FIREBASE_API_KEY=tu_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=tu_proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu_proyecto
VITE_FIREBASE_STORAGE_BUCKET=tu_proyecto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# Google Analytics para Firebase (OPCIONAL - activa la analítica de uso)
# Se obtiene en Firebase Console > Configuración del proyecto > Integraciones > Google Analytics
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
